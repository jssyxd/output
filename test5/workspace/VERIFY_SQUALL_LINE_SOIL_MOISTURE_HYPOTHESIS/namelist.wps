&share
    end_date = '2020-06-13_00:00:00'
    interval_seconds = 21600
    io_form_geogrid = 2
    max_dom = 1
    start_date = '2020-06-12_00:00:00'
    wrf_core = 'ARW'
/

&geogrid
    dx = 4000
    dy = 4000
    e_sn = 201
    e_we = 201
    geog_data_path = '/home/zkk/Build_WRF/geog'
    i_parent_start = 1
    j_parent_start = 1
    map_proj = 'lambert'
    opt_geogrid_tbl_path = './geogrid/'
    parent_grid_ratio = 1
    parent_id = 1
    ref_lat = 31.5
    ref_lon = 118.5
    stand_lon = 118.5
    truelat1 = 30
    truelat2 = 33
/

&ungrib
    out_format = 'WPS'
    prefix = 'FILE'
/

&metgrid
    fg_name = 'FILE'
    io_form_metgrid = 2
/

