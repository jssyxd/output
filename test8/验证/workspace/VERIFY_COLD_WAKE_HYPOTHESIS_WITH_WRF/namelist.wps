&share
    end_date = '2018-09-30_00:00:00', '2018-09-30_00:00:00'
    interval_seconds = 21600
    io_form_geogrid = 2
    max_dom = 2
    start_date = '2018-09-27_00:00:00', '2018-09-27_00:00:00'
    wrf_core = 'ARW'
/

&geogrid
    dx = 18000
    dy = 18000
    e_sn = 201, 201
    e_we = 201, 201
    geog_data_path = '/thfs1/home/mengf/geog_data/geog'
    i_parent_start = 1, 80
    j_parent_start = 1, 80
    map_proj = 'lambert'
    opt_geogrid_tbl_path = './geogrid/'
    parent_grid_ratio = 1, 3
    parent_id = 1, 1
    ref_lat = 26
    ref_lon = 130
    stand_lon = 130
    truelat1 = 20
    truelat2 = 32
/

&ungrib
    out_format = 'WPS'
    prefix = 'FILE'
/

&metgrid
    fg_name = 'FILE'
    io_form_metgrid = 2
/

